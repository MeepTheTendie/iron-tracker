# Iron Tracker Environment Variables
# Copy this file to .env and fill in your Supabase credentials

# Supabase Configuration
# Get these from your Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Analytics (optional)
# Get your GA4 measurement ID from analytics.google.com
VITE_GA_ID=G-XXXXXXXXXX

# Example (replace with your actual values):
# VITE_SUPABASE_URL=https://ibgkdujzzovcvyrfibjl.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# VITE_GA_ID=G-ABC123DEF456
