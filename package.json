{
  "name": "iron-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tsc": "tsc --noEmit",
    "check": "npm run format && npm run lint:fix && npm run tsc",
    "check:ci": "npm run format:check && npm run lint && npm run tsc && npm run test",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "deps:check": "npm outdated",
    "deps:update": "npm update",
    "security": "npm run audit && npm run lint && npm run tsc",
    "pre-commit": "npm run format && npm run lint:fix && npm run tsc && npm run test",
    "pre-push": "npm run check:ci && npm run audit",
    "setup": "chmod +x scripts/setup.sh && ./scripts/setup.sh",
    "start": "npm run dev",
    "analyze": "npm run build && npx vite-bundle-analyzer dist",
    "perf": "npm run build && npm install -g @lhci/cli@0.13.x && lhci autorun",
    "clean": "rm -rf dist/ node_modules/.cache/ .vite/",
    "clean:full": "rm -rf dist/ node_modules/ .vite/ && npm install",
    "docker:build": "docker build -t iron-tracker .",
    "docker:run": "docker run -p 80:80 iron-tracker",
    "release": "npm run check:ci && npm run build && npm publish --dry-run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.0.6",
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.0.5",
    "prettier": "^3.5.3",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",

    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
  }
}
