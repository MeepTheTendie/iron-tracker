{
  "name": "iron-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build && tsc",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tsc": "tsc --noEmit",
    "check": "bun run format && bun run lint:fix && bun run tsc",
    "check:ci": "bun run format:check && bun run lint && bun run tsc && bun run test",
    "audit": "bun audit",
    "audit:fix": "bun audit fix",
    "deps:check": "bun outdated",
    "deps:update": "bun update",
    "security": "bun run audit && bun run lint && bun run tsc",
    "pre-commit": "bun run format && bun run lint:fix && bun run tsc && bun run test",
    "pre-push": "bun run check:ci && bun run audit",
    "setup": "chmod +x scripts/setup.sh && ./scripts/setup.sh",
    "start": "bun run dev",
    "analyze": "bun run build && bunx vite-bundle-analyzer dist",
    "perf": "bun run build && bunx @lhci/cli@0.13.x autorun",
    "clean": "rm -rf dist/ node_modules/.cache/ .vite/",
    "clean:full": "rm -rf dist/ node_modules/ .vite/ && bun install",
    "docker:build": "docker build -t iron-tracker .",
    "docker:run": "docker run -p 80:80 iron-tracker",
    "release": "bun run check:ci && bun run build && bun publish --dry-run"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "clsx": "^2.1.1",
    "convex": "^1.31.5",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.0.6"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.0.5",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  },
  "packageManager": "bun@1.1.33"
}
